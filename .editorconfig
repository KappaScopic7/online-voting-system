root = true

# ---------------------------------------------------------
# 基本設定（全ファイル共通）
# ---------------------------------------------------------
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

# ---------------------------------------------------------
# JSON / YAML / MD （統一して4スペース）
# ---------------------------------------------------------
[*.json]
indent_size = 4

[*.yml]
indent_size = 4

[*.yaml]
indent_size = 4

[*.md]
indent_size = 4

# ---------------------------------------------------------
# Java（標準的なJavaフォーマット）
# ---------------------------------------------------------
[*.java]
indent_size = 4
indent_style = space

# ---------------------------------------------------------
# Gradle（スペース4を推奨）
# ---------------------------------------------------------
[*.gradle]
indent_size = 4
indent_style = space

# ---------------------------------------------------------
# Git関連
# ---------------------------------------------------------
[*.gitattributes]
indent_style = space
indent_size = 4

[*.gitignore]
indent_style = space
indent_size = 4
