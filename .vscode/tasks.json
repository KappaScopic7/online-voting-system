{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "ovs: db up (dev)",
            "type": "shell",
            "command": "docker",
            "args": ["compose", "-f", "compose.db.yml", "up", "-d"],
            "options": { "cwd": "${workspaceFolder}" },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            }
        },
        {
            "label": "ovs: db down (dev)",
            "type": "shell",
            "command": "docker",
            "args": ["compose", "-f", "compose.db.yml", "down"],
            "options": { "cwd": "${workspaceFolder}" },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            }
        },
        {
            "label": "ovs: db reset (dev)",
            "type": "shell",
            "command": "docker",
            "args": ["compose", "-f", "compose.db.yml", "down", "-v"],
            "options": { "cwd": "${workspaceFolder}" },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            }
        },

        {
            "label": "ovs: frontend install (dev)",
            "type": "shell",
            "command": "npm",
            "args": ["ci"],
            "options": { "cwd": "${workspaceFolder}/frontend" },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": false
            }
        },
        {
            "label": "ovs: frontend dev run",
            "type": "shell",
            "command": "npm",
            "args": ["run", "dev"],
            "options": { "cwd": "${workspaceFolder}/frontend" },
            "isBackground": true,
            "problemMatcher": {
                "base": "$tsc-watch",
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "vite v|> vite",
                    "endsPattern": "Local:\\s*http://localhost:5173"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": false
            }
        },
        // {
        //     "label": "ovs: frontend dev run",
        //     "type": "shell",
        //     "command": "npm",
        //     "args": ["run", "dev"],
        //     "options": { "cwd": "${workspaceFolder}/frontend" },
        //     "isBackground": true,
        //     "problemMatcher": [],
        //     "presentation": {
        //         "reveal": "always",
        //         "panel": "dedicated",
        //         "clear": false
        //     }
        // },
        {
            "label": "ovs: open browser (dev)",
            "type": "shell",
            "command": "C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-Command",
                "Start-Process 'http://localhost:5173'"
            ],
            "problemMatcher": [],
            "presentation": { "reveal": "never", "panel": "shared" }
        },
        {
            "label": "ovs: start (dev)",
            "dependsOn": [
                "ovs: db up (dev)",
                "ovs: nfc bridge (dev)",
                "ovs: frontend dev run",
                "ovs: open browser (dev)"
            ],
            "dependsOrder": "sequence",
            "problemMatcher": []
        },

        {
            "label": "ovs: up (prod-like)",
            "type": "shell",
            "command": "docker",
            "args": [
                "compose",
                "-f",
                "compose.prodlike.yml",
                "up",
                "-d",
                "--build"
            ],
            "options": { "cwd": "${workspaceFolder}" },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            }
        },
        {
            "label": "ovs: down (prod-like)",
            "type": "shell",
            "command": "docker",
            "args": ["compose", "-f", "compose.prodlike.yml", "down"],
            "options": { "cwd": "${workspaceFolder}" },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            }
        },
        {
            "label": "ovs: logs (prod-like)",
            "type": "shell",
            "command": "docker",
            "args": [
                "compose",
                "-f",
                "compose.prodlike.yml",
                "logs",
                "-f",
                "--tail=200"
            ],
            "options": { "cwd": "${workspaceFolder}" },
            "isBackground": true,
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": false
            }
        },
        {
            "label": "ovs: open browser (prod-like)",
            "type": "shell",
            "command": "C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-Command",
                "Start-Process 'http://localhost:8081'"
            ],
            "problemMatcher": [],
            "presentation": { "reveal": "never", "panel": "shared" }
        },
        {
            "label": "ovs: start (prod-like)",
            "dependsOn": [
                "ovs: up (prod-like)",
                "ovs: nfc bridge (prod-like)",
                "ovs: open browser (prod-like)"
            ],
            "dependsOrder": "sequence",
            "problemMatcher": []
        },
        {
            "label": "ovs: nfc bridge (dev)",
            "type": "shell",
            "command": ".\\gradlew.bat",
            "args": ["runNfcBridge"],
            "options": {
                "cwd": "${workspaceFolder}/backend",
                "env": {
                    "OVS_NFC_BRIDGE": "1"
                }
            },
            "isBackground": true,

            "problemMatcher": {
                "base": "$msCompile",
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "runNfcBridge",
                    "endsPattern": "listening on http://127\\.0\\.0\\.1:39123"
                }
            },

            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": false
            }
        },
        {
            "label": "ovs: nfc bridge (prod-like)",
            "type": "shell",
            "command": ".\\gradlew.bat",
            "args": ["runNfcBridge"],
            "options": {
                "cwd": "${workspaceFolder}/backend",
                "env": {
                    "OVS_NFC_BRIDGE": "1"
                }
            },
            "isBackground": true,
            "problemMatcher": {
                "base": "$msCompile",
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "runNfcBridge",
                    "endsPattern": "listening on http://127\\.0\\.0\\.1:39123"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": false
            }
        }
    ]
}
