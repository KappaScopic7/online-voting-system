{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "ovs: up (prod-like)",
            "type": "shell",
            "command": "docker",
            "args": [
                "compose",
                "-f",
                "docker-compose.dockerfile.yml",
                "up",
                "-d",
                "--build"
            ],
            "options": { "cwd": "${workspaceFolder}" },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            }
        },
        {
            "label": "ovs: down (prod-like)",
            "type": "shell",
            "command": "docker",
            "args": ["compose", "-f", "docker-compose.dockerfile.yml", "down"],
            "options": { "cwd": "${workspaceFolder}" },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            }
        },
        {
            "label": "ovs: logs (prod-like)",
            "type": "shell",
            "command": "docker",
            "args": [
                "compose",
                "-f",
                "docker-compose.dockerfile.yml",
                "logs",
                "-f",
                "--tail=200"
            ],
            "options": { "cwd": "${workspaceFolder}" },
            "isBackground": true,
            "problemMatcher": {
                "owner": "ovs-logs",
                "pattern": [
                    {
                        "regexp": "^(.*)$",
                        "kind": "file",
                        "file": 1,
                        "message": 1
                    }
                ],
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^(.*)$",
                    "endsPattern": "$^"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": false
            }
        },
        {
            "label": "ovs: open browser (prod-like)",
            "type": "shell",
            "command": "C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-Command",
                "Start-Process 'http://localhost:8081'"
            ],
            "problemMatcher": [],
            "presentation": { "reveal": "never", "panel": "shared" }
        },
        {
            "label": "ovs: start (prod-like)",
            "dependsOn": [
                "ovs: up (prod-like)",
                "ovs: logs (prod-like)",
                "ovs: open browser (prod-like)"
            ],
            "dependsOrder": "sequence",
            "problemMatcher": []
        }
    ]
}
