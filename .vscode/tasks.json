{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "ovs: db up",
            "type": "shell",
            "command": "docker",
            "args": ["compose", "up", "-d"],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            }
        },
        {
            "label": "ovs: frontend dev",
            "type": "shell",
            "command": "npm",
            "args": ["run", "dev"],
            "options": {
                "cwd": "${workspaceFolder}/frontend"
            },
            "isBackground": true,
            "problemMatcher": {
                "owner": "ovs-frontend",
                "pattern": {
                    "regexp": ".+",
                    "message": 0
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".+",
                    "endsPattern": "(Local:\\s+http://localhost:5173|ready in\\s+\\d+\\s*ms)"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            }
        }
    ]
}
