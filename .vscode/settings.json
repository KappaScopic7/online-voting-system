{
    // 共通
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false,

    // 保存時に Prettier で自動整形
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode",

    // ESLint の自動修正は保存時に実行しない（手動 or CI で実行する方針）
    "editor.codeActionsOnSave": {
        "source.fixAll.eslint": false
    },

    // Java → 4スペース
    "[java]": {
        "editor.tabSize": 4,
        "editor.insertSpaces": true
    },

    // YAML → 2スペース
    "[yml]": {
        "editor.tabSize": 2,
        "editor.insertSpaces": true
    },
    "[yaml]": {
        "editor.tabSize": 2,
        "editor.insertSpaces": true
    },

    // JSON → 4スペース + Prettier
    "[json]": {
        "editor.tabSize": 4,
        "editor.insertSpaces": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },

    // Gradle → 4スペース
    "[gradle]": {
        "editor.tabSize": 4,
        "editor.insertSpaces": true
    },

    // Markdown → 4スペース + Prettier
    "[markdown]": {
        "editor.tabSize": 4,
        "editor.insertSpaces": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },

    // JS/TS で Prettier を既定フォーマッタにする
    "[javascript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[javascriptreact]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[typescript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[typescriptreact]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.tabSize": 4,
        "editor.insertSpaces": true
    },

    "java.compile.nullAnalysis.mode": "disabled",
    "java.configuration.updateBuildConfiguration": "interactive"
}
